DATABASE_URL=postgres://ssanta:ssanta@localhost:5432/ssanta?sslmode=disable
HTTP_ADDR=:8080
MIGRATIONS_DIR=migrations
SESSION_SECRET=dev-secret-change-me-to-at-least-32-bytes
# Set to true when the server sits behind a trusted proxy that populates
# X-Forwarded-For authoritatively (e.g. DigitalOcean App Platform). Leave false
# for direct exposure so attacker-supplied headers can't bypass rate limits.
TRUST_PROXY_HEADERS=false
